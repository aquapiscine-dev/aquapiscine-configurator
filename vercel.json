{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/chat_vercel.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api",
      "dest": "api/index.py"
    },
    {
      "src": "/api/chat",
      "dest": "api/chat_vercel.py"
    }
  ]
}
